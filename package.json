{
  "name": "@eggai-tech/mo",
  "version": "0.2.0",
  "description": "Eval runner for wally agents. CLI (`mo run`) and a programmatic `runEvals` entry point.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eggai-tech/platform-poc.git",
    "directory": "mo"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./cli": "./dist/index.js"
  },
  "bin": {
    "mo": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@opentelemetry/api": "^1.9.1",
    "ai": "^6.0.168",
    "commander": "^14.0.3",
    "langfuse": "^3.38.20",
    "p-limit": "^7.3.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
